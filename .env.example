# =============================================================================
# Query & Buy — environment template
# Copy this file to `.env.local` and fill in real values there.
# COMMIT this file (placeholders only). NEVER commit `.env.local`.
# =============================================================================

# --- Supabase: client-safe (exposed to the browser) -------------------------
# These are PUBLIC by design. The anon key is safe to ship to the browser
# because Row Level Security (RLS) is the authorization layer. Not a secret.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase: server-only (NEVER expose to the browser) --------------------
# Bypasses RLS. Used only by server actions / route handlers / the worker.
# Leave blank until you need server-side admin access. No NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin (simple gate) ----------------------------------------------------
# Comma-separated emails allowed into /admin. Requires SUPABASE_SERVICE_ROLE_KEY
# above so the admin views can read all reports (bypassing RLS).
ADMIN_EMAILS=

# --- AI: listing generation (server-only secrets) ---------------------------
# Gemini powers "Generate with AI" on /sell (Sprint 6A). Server-only.
GEMINI_API_KEY=
# Optional: override the provider (gemini | openai | claude). Defaults to gemini.
AI_PROVIDER=gemini
# Future providers / worker — not needed to boot the web app.
ANTHROPIC_API_KEY=

# --- Transactional email: Resend (Sprint 9 trust layer) ---------------------
# Optional. Without RESEND_API_KEY, emails are skipped gracefully (in-app
# notifications still fire). Emails are sent only to VERIFIED addresses.
RESEND_API_KEY=
# Verified sender, e.g. "Query & Buy <noreply@yourdomain.com>". Defaults to the
# Resend sandbox sender for local testing.
EMAIL_FROM=
# Absolute base URL used for email CTA links (e.g. https://queryandbuy.ae).
NEXT_PUBLIC_SITE_URL=
